{
  "name": "solon-slide-studio",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run server\" \"npm run client\"",
    "server": "node server/index.js",
    "client": "cd client && npm run dev",
    "build": "cd client && npm run build",
    "start": "concurrently \"node server/index.js\" \"cd client && npm run dev\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint server/ && cd client && npm run lint",
    "test:e2e": "playwright test --project=all",
    "test:e2e:html": "playwright test --project=html-flow",
    "test:e2e:ui": "playwright test --ui"
  },
  "dependencies": {
    "archiver": "^7.0.1",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "mammoth": "^1.12.0",
    "multer": "^2.1.1",
    "node-html-parser": "^7.1.0",
    "pdf-parse": "^2.4.5",
    "exceljs": "^4.4.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "concurrently": "^8.2.2",
    "cross-env": "^10.1.0",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "supertest": "^7.0.0",
    "vitest": "^4"
  }
}
