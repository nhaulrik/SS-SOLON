# Server port (default: 3001)
PORT=3001

# Override runtime data directories (optional — defaults to server/temp, server/output, etc.)
# Useful for running tests against an isolated directory.
# TEMP_DIR=/tmp/solon/temp
# OUTPUT_DIR=/tmp/solon/output
# PATCHES_DIR=/tmp/solon/patches
# CHAINS_DIR=/tmp/solon/chains

# Set to "test" when running tests so the server does not start listening.
# NODE_ENV=test
